# Copy this file to ".env" before running `docker compose up -d`.
# Use forward slashes for Windows paths, for example: D:/Media

JF_SERVER_PORT=8096
JF_WEB_PORT=8083

# Project source paths
JF_SERVER_SRC_DIR=./server
JF_WEB_SRC_DIR=./web

# Dev data paths
JF_CONFIG_DIR=./.jf-dev/config
JF_CACHE_DIR=./.jf-dev/cache
JF_NUGET_DIR=./.jf-dev/nuget
JF_WEB_NODE_MODULES_DIR=./.jf-dev/jf-web-node_modules

# Media mount path on host (example: D:/Media)
JF_MEDIA_DIR=./.jf-dev/media
